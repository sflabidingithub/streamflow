# Enforce LF for shell scripts and other Linux-sensitive files
*.sh        text eol=lf
*.bash      text eol=lf
Dockerfile  text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Binary files
*.sqlite    binary
*.db        binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
